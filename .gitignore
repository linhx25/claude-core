# ── Personal / local-only ─────────────────────────────────────────────────────
personal.md                  # Machine-specific habits and preferences
personal-*.md                # Any personal variant files
*.local.*                    # Claude Code local settings (e.g. .claude/settings.local.json)

# ── Secrets & credentials ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
secrets/
*.pem
*.key
*.p12
*.pfx

# ── Claude Code auto-generated ────────────────────────────────────────────────
.claude/snapshots/           # Pre-compact plan snapshots (auto-generated by hook)
quality_reports/session-logs/ # Session logs (personal work diary, not shareable)

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.mypy_cache/
.ruff_cache/
.pytest_cache/
.ipynb_checkpoints/
*.egg-info/
dist/
build/
.venv/
venv/
.python-version

